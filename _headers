# Netlify cache headers (inert on the local python server, picked up on deploy)
#
# HTML is always revalidated; everything else caches hard because changes ship
# under new filenames or a bumped ?v=N query — this permanently ends the
# stale-cache problem we kept hitting during local development.

/*
  X-Content-Type-Options: nosniff

/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

/404.html
  Cache-Control: no-cache

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/data/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable
